            collect_inline(child, ctx, para)?;
        }
        Ok(())
    }
    fn collect_inline(
        node: &Handle,
        ctx: &InlineCtx,
        para: &mut Paragraph,
    ) -> Result<(), DocxError> {
        match &node.data {
            NodeData::Text { contents } => {
                let text = contents.borrow().to_string();
                if text.is_empty() {
                    return Ok(());
                }
                let mut run = Run::new().add_text(text);
                if ctx.bold {
                    run = run.bold();
                }
                if ctx.italic {
                    run = run.italic();
                }
                if ctx.code {
                    run = run.fonts(RunFonts::new().ascii("Consolas"));
                }
                let owned = std::mem::take(para);
                *para = owned.add_run(run);
            }
            NodeData::Element { name, .. } => {
                let tag = name.local.as_ref();
                let mut nested = ctx.clone();
                match tag {
                    "strong" | "b" => nested.bold = true,
                    "em" | "i" => nested.italic = true,
                    "code" => nested.code = true,
                    "br" => {
                        let owned = std::mem::take(para);
                        *para = owned
                            .add_run(
                                Run::new().add_break(docx_rs::BreakType::TextWrapping),
                            );
                        return Ok(());
                    }
                    "a" => {}
                    "span" => {}
                    other => {
                        return Err(DocxError::Unsupported {
                            tag: other.to_string(),
                        });
                    }
                }
                collect_inline_children(node, &nested, para)?;
            }
            NodeData::Comment { .. }
            | NodeData::Doctype { .. }
            | NodeData::ProcessingInstruction { .. }
            | NodeData::Document => {}
        }
        Ok(())
    }
}
#[derive(Clone)]
pub struct AppState {}
#[tokio::main]
async fn main() -> anyhow::Result<()> {
    let __rb_dotenv_loaded: Option<std::path::PathBuf> = ::dotenvy::dotenv().ok();
    let __rb_log_subscriber = ::tracing_subscriber::fmt()
        .json()
        .flatten_event(true)
        .with_current_span(true)
        .with_span_list(true)
        .with_target(true)
        .with_max_level(::tracing::Level::INFO)
        .finish();
    let _ = ::tracing::subscriber::set_global_default(__rb_log_subscriber);
    if let Some(path) = __rb_dotenv_loaded.as_ref() {
        ::tracing::info!(
            target : "rublocks::app", path = % path.display(), "rublocks: loaded .env"
        );
    }
    let state = AppState {};
    let mut router = Router::new().route("/health", get(health));
    router = router.route("/report.docx", get(route_report));
    if std::env::var("RUBLOCKS_DEV").is_ok() {
        router = router.route("/", get(dev_index));
        router = router
            .route("/__rublocks/livereload.js", get(dev_snippet))
            .route("/__rublocks/events", get(dev_events));
        eprintln!("rublocks: dev endpoints enabled at /__rublocks/*");
    }
    router = router
        .layer(
            tower_http::trace::TraceLayer::new_for_http()
                .make_span_with(|request: &axum::http::Request<_>| {
                    let request_id: ::std::string::String = request
                        .headers()
                        .get("x-request-id")
                        .and_then(|v| v.to_str().ok())
                        .map(::std::string::String::from)
                        .unwrap_or_else(|| {
                            ::std::format!("{:032x}", crate ::_rb_log::rand_request_id())
                        });
                    let method = ::std::format!("{}", request.method());
                    let path = request.uri().path().to_string();
                    let route = request
                        .extensions()
                        .get::<axum::extract::MatchedPath>()
                        .map(|m| m.as_str().to_string())
                        .unwrap_or_else(|| path.clone());
                    ::tracing::info_span!(
                        target : "rublocks::request", "http_request", request_id = %
                        request_id, method = % method, path = % path, route = % route,
                    )
                }),
        );
    router = router
        .layer(
            tower_http::set_header::SetResponseHeaderLayer::if_not_present(
                http::header::HeaderName::from_static("x-app-version"),
                http::HeaderValue::from_static("0.0.0"),
            ),
        );
    router = router.layer(axum::middleware::from_fn(_rb_encoding::enforce));
    let app = router.with_state(state);
    let listener = tokio::net::TcpListener::bind("0.0.0.0:3000").await?;
    println!("rublocks app listening on http://0.0.0.0:3000");
    axum::serve(listener, app).await?;
    Ok(())
}
async fn health() -> &'static str {
    "ok"
}
async fn route_report(
    axum::extract::State(__state): axum::extract::State<AppState>,
) -> axum::response::Response {
    let __rb_input_errors: Vec<crate::_rb_input::FieldError> = Vec::new();
    let __rb_block_start_0: ::std::time::Instant = ::std::time::Instant::now();
    let __rb_block_span_0 = ::tracing::info_span!(
        target : "rublocks::block", "block", block = "time.now", format = "%Y-%m-%d"
    );
    let _rb_block_guard_0 = __rb_block_span_0.enter();
    let __block_now: String = {
        let __rb_now = chrono::Utc::now();
        __rb_now.format("%Y-%m-%d").to_string()
    };
    ::tracing::info!(
        target : "rublocks::block", duration_us = __rb_block_start_0.elapsed()
        .as_micros() as u64, "ok"
    );
    let __rb_block_start_1: ::std::time::Instant = ::std::time::Instant::now();
    let __rb_block_span_1 = ::tracing::info_span!(
        target : "rublocks::block", "block", block = "docx.render", source_format =
        "markdown"
    );
    let _rb_block_guard_1 = __rb_block_span_1.enter();
    let __block_doc: bytes::Bytes = {
        let __src: String = (__block_now.clone()).to_string();
        match crate::_rb_docx::render(&__src, crate::_rb_docx::SourceFormat::Markdown) {
            Ok(b) => b,
            Err(e) => {
                {
                    let __rb_err_ref: &(dyn ::std::error::Error + 'static) = &(e);
                    let __rb_err_chain: ::std::vec::Vec<::std::string::String> = crate::_rb_log::error_chain(
                        __rb_err_ref,
                    );
                    let __rb_err_backtrace: ::std::option::Option<
                        ::std::string::String,
                    > = crate::_rb_log::error_backtrace();
                    ::tracing::error!(
                        target : "rublocks::block", duration_us = __rb_block_start_1
                        .elapsed().as_micros() as u64, error = % __rb_err_ref, error
                        .chain = ? __rb_err_chain, backtrace = __rb_err_backtrace
                        .as_deref(), "block failed"
                    );
                }
                return crate::_rb_runtime::docx_error(e);
            }
        }
    };
    ::tracing::info!(
        target : "rublocks::block", duration_us = __rb_block_start_1.elapsed()
        .as_micros() as u64, "ok"
    );
    axum::response::IntoResponse::into_response((
        [(axum::http::header::CONTENT_LANGUAGE, "en-US")],
        axum::Json({
            let mut __obj = ::serde_json::Map::new();
            __obj
                .insert(
                    "size".to_string(),
                    ::serde_json::to_value(&(__block_doc.clone()))
                        .unwrap_or(::serde_json::Value::Null),
                );
            ::serde_json::Value::Object(__obj)
        }),
    ))
}
async fn dev_index() -> impl axum::response::IntoResponse {
    (
        [(axum::http::header::CONTENT_LANGUAGE, "en-US")],
        axum::response::Html(
            "<!DOCTYPE html>\n<html lang=\"en-US\">\n<head>\n  <meta charset=\"utf-8\">\n  <meta name=\"description\" content=\"snapshot test\">\n  <title>rb_test — rublocks dev</title>\n  <script src=\"/__rublocks/livereload.js\"></script>\n</head>\n<body style=\"font-family: system-ui, sans-serif; max-width: 40rem; margin: 4rem auto; color: #222;\">\n  <h1 style=\"margin-bottom: 0.25rem;\">rb_test</h1>\n  <p style=\"color: #666; margin: 0 0 0.5rem;\">snapshot test</p>\n  <p style=\"color: #888; margin-top: 0;\">rublocks dev mode</p>\n  <p>Edit <code>main.json</code> and save — this page will reload automatically.</p>\n</body>\n</html>\n",
        ),
    )
}
async fn dev_snippet() -> impl axum::response::IntoResponse {
    ([(axum::http::header::CONTENT_TYPE, "application/javascript")], LIVERELOAD_JS)
}
async fn dev_events() -> axum::response::Sse<
    impl futures_util::Stream<
        Item = Result<axum::response::sse::Event, std::convert::Infallible>,
    >,
> {
    use futures_util::stream::StreamExt;
    let initial = futures_util::stream::once(async {
        Ok::<
            axum::response::sse::Event,
            std::convert::Infallible,
        >(axum::response::sse::Event::default().comment("rublocks dev ready"))
    });
    let pending = futures_util::stream::pending::<
        Result<axum::response::sse::Event, std::convert::Infallible>,
    >();
    axum::response::Sse::new(initial.chain(pending))
        .keep_alive(axum::response::sse::KeepAlive::default())
}
const LIVERELOAD_JS: &str = "(function () {\n  let everConnected = false;\n  function connect() {\n    const es = new EventSource('/__rublocks/events');\n    es.onopen = function () {\n      if (everConnected) {\n        location.reload();\n      }\n      everConnected = true;\n    };\n    es.onerror = function () {\n      es.close();\n      setTimeout(connect, 500);\n    };\n  }\n  connect();\n})();\n";
