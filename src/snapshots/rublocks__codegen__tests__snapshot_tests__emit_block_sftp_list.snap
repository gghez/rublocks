            let config = Arc::new(russh::client::Config::default());
            let handler = SftpClientHandler {
                expected_fp: self.host_key_fingerprint.clone(),
            };
            let mut session = russh::client::connect(
                    config,
                    (self.host.as_str(), self.port),
                    handler,
