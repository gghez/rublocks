#!/usr/bin/env sh
# rublocks installer (Linux/macOS).
#
# This file is a template: it is committed with __RUBLOCKS_VERSION__ as a
# placeholder and is substituted by the release workflow before being attached
# to each GitHub release as `install.sh`.
#
# Usage (latest release):
#   curl -LsSf https://github.com/gghez/rublocks/releases/latest/download/install.sh | sh
#
# Usage (pinned version):
#   curl -LsSf https://github.com/gghez/rublocks/releases/download/v0.1.0/install.sh | sh
#
# Environment variables:
#   RUBLOCKS_HOME  install root (default: $HOME/.rublocks). Binary lands in $RUBLOCKS_HOME/bin.

set -eu

VERSION="__RUBLOCKS_VERSION__"
REPO="gghez/rublocks"

RUBLOCKS_HOME="${RUBLOCKS_HOME:-${HOME}/.rublocks}"
INSTALL_DIR="${RUBLOCKS_HOME}/bin"

err() { printf 'error: %s\n' "$*" >&2; exit 1; }
log() { printf '%s\n' "$*"; }

need_cmd() { command -v "$1" >/dev/null 2>&1 || err "missing required command: $1"; }

detect_target() {
    os="$(uname -s)"
    arch="$(uname -m)"
    case "${os}-${arch}" in
        Linux-x86_64)         echo "x86_64-unknown-linux-gnu" ;;
        Linux-aarch64|Linux-arm64) err "rublocks does not yet ship a Linux aarch64 build; please open an issue at https://github.com/${REPO}/issues" ;;
        Darwin-x86_64)        echo "x86_64-apple-darwin" ;;
        Darwin-arm64)         echo "aarch64-apple-darwin" ;;
        *) err "unsupported platform: ${os}-${arch}" ;;
    esac
}

verify_checksum() {
    archive="$1"
    sumfile="$2"
    expected="$(awk '{print $1}' "${sumfile}")"
    if command -v sha256sum >/dev/null 2>&1; then
        actual="$(sha256sum "${archive}" | awk '{print $1}')"
    else
        actual="$(shasum -a 256 "${archive}" | awk '{print $1}')"
    fi
    if [ "${expected}" != "${actual}" ]; then
        err "checksum mismatch for $(basename "${archive}")
  expected: ${expected}
  actual:   ${actual}"
    fi
}

main() {
    need_cmd curl
    need_cmd tar
    need_cmd uname

    target="$(detect_target)"
    name="rublocks-v${VERSION}-${target}"
    base="https://github.com/${REPO}/releases/download/v${VERSION}"
    archive_url="${base}/${name}.tar.gz"
    sum_url="${archive_url}.sha256"

    log "Installing rublocks v${VERSION} (${target})"

    tmp="$(mktemp -d 2>/dev/null || mktemp -d -t rublocks)"
    trap 'rm -rf "${tmp}"' EXIT INT TERM

    log "  Downloading ${archive_url}"
    curl --fail --location --silent --show-error --output "${tmp}/archive.tar.gz" "${archive_url}"
    curl --fail --location --silent --show-error --output "${tmp}/archive.tar.gz.sha256" "${sum_url}"
    verify_checksum "${tmp}/archive.tar.gz" "${tmp}/archive.tar.gz.sha256"

    log "  Extracting"
    tar -xzf "${tmp}/archive.tar.gz" -C "${tmp}"

    mkdir -p "${INSTALL_DIR}"
    install -m 0755 "${tmp}/${name}/rublocks" "${INSTALL_DIR}/rublocks"

    log ""
    log "Installed: ${INSTALL_DIR}/rublocks"
    "${INSTALL_DIR}/rublocks" --version || true

    case ":${PATH}:" in
        *":${INSTALL_DIR}:"*) ;;
        *)
            log ""
            log "Add this line to your shell config (.bashrc / .zshrc / etc.):"
            log "  export PATH=\"${INSTALL_DIR}:\$PATH\""
            ;;
    esac
}

main "$@"
