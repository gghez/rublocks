{
  "path": "/api/posts",
  "method": "GET",
  "kind": "api",

  "summary":     "List published posts",
  "description": "Returns a paginated list of posts whose published_at is non-null, ordered by most recent first.",
  "tags":        ["posts"],

  "input": {
    "query": {
      "limit":  { "type": "int", "default": 20, "max": 100 },
      "offset": { "type": "int", "default": 0,  "min": 0 }
    }
  },

  "process": [
    {
      "name":     "posts",
      "block":    "db.find_many",
      "table":    "posts",
      "where":    { "published_at": { "is_not_null": true } },
      "order_by": "-published_at",
      "limit":    "$input.query.limit",
      "offset":   "$input.query.offset"
    }
  ],

  "view": {
    "data":   "$posts",
    "limit":  "$input.query.limit",
    "offset": "$input.query.offset"
  }
}
