{
  "path": "/api/posts/:slug",
  "method": "GET",
  "kind": "api",

  "summary":     "Get a single published post",
  "description": "Returns the post identified by slug along with its author. Drafts (published_at IS NULL) are treated as non-existent and yield 404.",
  "tags":        ["posts"],

  "input": {
    "path": {
      "slug": { "type": "string", "required": true }
    }
  },

  "process": [
    {
      "name":  "post",
      "block": "db.find_one",
      "table": "posts",
      "where": { "slug": "$input.path.slug", "published_at": { "is_not_null": true } },
      "on_missing": {
        "block":       "error",
        "status":      404,
        "code":        "post_not_found",
        "description": "No published post matches the given slug."
      }
    },
    {
      "name":  "author",
      "block": "db.find_one",
      "table": "authors",
      "where": { "id": "$post.author_id" }
    }
  ],

  "view": {
    "id":           "$post.id",
    "slug":         "$post.slug",
    "title":        "$post.title",
    "body":         "$post.body",
    "published_at": "$post.published_at",
    "author": {
      "id":   "$author.id",
      "name": "$author.name"
    }
  }
}
